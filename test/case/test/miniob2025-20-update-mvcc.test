-- echo miniob2025 update mvcc setup
create table mvcc_update_t(id int, value int, note char);
create index idx_mvcc_update_id on mvcc_update_t(id);
insert into mvcc_update_t values(1, 10, 'a');
insert into mvcc_update_t values(2, 20, 'b');
insert into mvcc_update_t values(3, 30, 'c');

-- echo single connection update visibility
begin;
update mvcc_update_t set value=11 where id=1;
select value from mvcc_update_t where id=1;
commit;
select value from mvcc_update_t where id=1;

-- echo rollback update
begin;
update mvcc_update_t set value=99 where id=2;
select value from mvcc_update_t where id=2;
rollback;
select value from mvcc_update_t where id=2;

-- echo multi connection serial visibility
-- connect c1
-- connect c2
-- connection c1
begin;
update mvcc_update_t set note='x' where id=3;
select note from mvcc_update_t where id=3;
-- connection c2
select note from mvcc_update_t where id=3;
-- connection c1
commit;
-- connection c2
select note from mvcc_update_t where id=3;

-- echo indexed column update under mvcc
-- connection default
begin;
update mvcc_update_t set id=4 where value=20;
commit;
-- sort select * from mvcc_update_t;
select * from mvcc_update_t where id=4;

-- echo unique index non-key update under mvcc
create table t_update_mvcc(id int, age int, name char(4));
create unique index t_update_mvcc_id_index on t_update_mvcc(id);
insert into t_update_mvcc values(1, 1, 'a');
