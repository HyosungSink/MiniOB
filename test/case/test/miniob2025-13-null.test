-- echo 6. aggregation with null columns
CREATE TABLE p13_p13_null_table3(id int not null, num int null);
INSERT INTO p13_p13_null_table3 VALUES (1, null);
INSERT INTO p13_p13_null_table3 VALUES (2, null);
SELECT count(num) FROM p13_p13_null_table3;
SELECT min(num) FROM p13_p13_null_table3;
SELECT max(num) FROM p13_p13_null_table3;
SELECT avg(num) FROM p13_p13_null_table3;
