-- echo miniob2025 13 null setup
create table null_t(id int not null, age int null, score float null, tag char);
insert into null_t values(1, 18, 1.5, 'a');
insert into null_t values(2, null, 2.5, 'b');
insert into null_t values(3, 30, null, null);

-- echo null checks
-- sort select id from null_t where age is null;
-- sort select id from null_t where score is not null;
select id, age + 1 as age_plus from null_t where id=2;
select count(*), count(age), count(score) from null_t;
update null_t set age=null where id=1;
-- sort select id, age from null_t;

-- echo null update assignment expressions
create table null_table3(id int not null, num int null);
create table null_table4(id int not null, num int null, name char(10) null);
insert into null_table3 values(3, null);
insert into null_table3 values(7, 7);
insert into null_table4 values(2, 2, 'n2');
insert into null_table4 values(4, 4, 'n4');
insert into null_table4 values(2, 2, 'n2');
update null_table4 set num=null where id=2;
update null_table4 set name=null where num is null;
update null_table4 set id=null where num is null;
update null_table4 set num=(select null_table3.num from null_table3 where null_table3.id=3) where id=4;
-- sort select id, num, name from null_table4;

-- echo null update-select regression
create table null_table7(id int not null, num int null);
create table null_table8(id int not null, num int null, name char(10) null);
insert into null_table7 values(3, null);
insert into null_table8 values(2, 2, 'n2');
insert into null_table8 values(7, 7, 'n7');
update null_table8 set num=null where id=2;
update null_table8 set name=null where num is null;
update null_table8 set id=null where num is null;
update null_table8 set num=(select null_table7.num from null_table7 where null_table7.id=3) where id=7;

-- echo null unique update subquery regression
create table null_table5(id int null, num int not null);
create unique index index_id on null_table5(id);
insert into null_table5 values(1,1);
insert into null_table5 values(1,1);
insert into null_table5 values(null,1);
create table null_table6(id1 int null, id2 int null, num int not null);
create unique index index_id on null_table6(id1, id2);
insert into null_table6 values(2,null,2);
insert into null_table6 values(1,null,2);
insert into null_table6 values(null,null,1);
insert into null_table6 values(8,null,8);
update null_table6 set id1=(select null_table5.id from null_table5 where null_table5.num=1),id2=4 where id1=8 and num=8;
select * from null_table6;

-- echo null boundary errors
insert into null_t values(null, 1, 1.0, 'x');
select id from null_t where missing_col is null;

-- echo fused primary null coverage
-- echo initialization
CREATE TABLE p13_null_table(id int not null, num int null, price float not null, birthday date null);
CREATE TABLE p13_p13_null_table2(id int not null, num int null, price float not null, birthday date null);
CREATE INDEX index_num on p13_null_table(num);

