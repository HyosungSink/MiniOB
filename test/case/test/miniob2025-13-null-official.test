# -- unique index
CREATE TABLE null_table5(id int null, num int not null);
CREATE UNIQUE INDEX index_id on null_table5(id);

INSERT INTO null_table5 VALUES(1,1);
# '''
# correct output:
# success
# '''
INSERT INTO null_table5 VALUES(1,1);
# '''
# correct output:
# failure
# '''
INSERT INTO null_table5 VALUES(null,1);
# '''
# correct output:
# success
# '''
INSERT INTO null_table5 VALUES(1,null);
# '''
# correct output:
# failure
# '''

# -- null in join
CREATE TABLE null_table6(id1 int null, id2 int null, num int not null);

CREATE UNIQUE INDEX index_id on null_table6(id1,id2);

INSERT INTO null_table6 VALUES(1,null,1);
INSERT INTO null_table6 VALUES(2,null,2);
INSERT INTO null_table6 VALUES(null,null,1);
INSERT INTO null_table6 VALUES(null,null,2);

# -- null in join
UPDATE null_table6 set id1=2 where id1 IS NULL and id2 is NULL;

SELECT * FROM null_table6;
# '''
# correct output:
# 1 | NULL | 1
# 2 | NULL | 2
# 2 | NULL | 1
# 2 | NULL | 2
# '''
