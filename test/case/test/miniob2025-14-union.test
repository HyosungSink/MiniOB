-- echo miniob2025 union setup
create table union_a(id int, tag char);
create table union_b(id int, tag char);
create table union_c(id int, tag char);
insert into union_a values(1, 'a');
insert into union_a values(1, 'a');
insert into union_a values(2, 'b');
insert into union_b values(2, 'b');
insert into union_b values(3, 'c');
insert into union_c values(3, 'c');
insert into union_c values(4, 'd');

