-- echo official miniob2025-10-group-by-official

# -- init data
CREATE TABLE aggregation_func(id int, num int, price float, addr char(4), birthday date);

create table t_group_by (id int not null, score int not null, name char(1) null);

create table t_group_by_2 (id int not null, age int not null);

insert into t_group_by VALUES (8, 3, 'X');
insert into t_group_by VALUES (6, 2, 'L');

# -- insert data:50
INSERT INTO aggregation_func VALUES (90, 1, 16.0, 'FJ', '2022-03-24');
