INSERT INTO aggregation_func VALUES (40, 1, 6.0, 'U', '2008-01-29');

SELECT min(price) FROM aggregation_func WHERE num < 1;

SELECT count(*,num) FROM aggregation_func;

SELECT id FROM aggregation_func where min(num) > 1;

DROP TABLE aggregation_func;
DROP TABLE t_group_by;
DROP TABLE t_group_by_2;

