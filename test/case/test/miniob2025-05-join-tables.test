-- echo miniob2025 05 join tables setup
create table join_a(id int, dept int, name char);
create table join_b(dept int, score int);
create table join_c(id int, flag int);
insert into join_a values(1, 10, 'a');
insert into join_a values(2, 20, 'b');
insert into join_a values(3, 10, 'c');
insert into join_b values(10, 100);
insert into join_b values(20, 200);
insert into join_c values(1, 1);
insert into join_c values(3, 0);

-- echo join checks
-- sort select a.id, a.name, b.score from join_a as a inner join join_b as b on a.dept=b.dept;
-- sort select a.id, b.score, c.flag from join_a as a inner join join_b as b on a.dept=b.dept, join_c as c where c.id=a.id;
-- sort select a.id, b.score from join_a a inner join join_b b on a.dept=b.dept and b.score>=100 where a.id>=2;

-- echo join boundary errors
select id from join_a inner join join_b on join_a.dept=join_b.dept;
select a.id from join_a as a inner join missing_join as m on a.id=m.id;
select a.missing_col from join_a as a inner join join_b as b on a.dept=b.dept;

-- echo constant join predicate regression
CREATE TABLE join_table_2(id int, age int);
CREATE TABLE join_table_3(id int, level int);
INSERT INTO join_table_2 VALUES (11, 18);
INSERT INTO join_table_2 VALUES (11, 23);
INSERT INTO join_table_3 VALUES (2, 39);
INSERT INTO join_table_3 VALUES (3, 29);
Select * from join_table_2 inner join join_table_3 on 1>1.5;

-- echo fused primary join coverage
-- echo initialization
CREATE TABLE j5p_1(id int, name char);
CREATE TABLE j5p_2(id int, num int);
CREATE TABLE j5p_3(id int, num2 int);
create table j5p_empty_1(id int, num_empty_1 int);
create table j5p_empty_2(id int, num_empty_2 int);

INSERT INTO j5p_1 VALUES (1, 'a');
INSERT INTO j5p_1 VALUES (2, 'b');
INSERT INTO j5p_1 VALUES (3, 'c');
INSERT INTO j5p_2 VALUES (1, 2);
INSERT INTO j5p_2 VALUES (2, 15);
INSERT INTO j5p_3 VALUES (1, 120);
INSERT INTO j5p_3 VALUES (3, 800);

-- echo 1. Select
-- sort Select * from j5p_1 inner join j5p_2 on j5p_1.id=j5p_2.id;
-- sort Select j5p_1.name from j5p_1 inner join j5p_2 on j5p_1.id=j5p_2.id;
-- sort Select j5p_2.num from j5p_1 inner join j5p_2 on j5p_1.id=j5p_2.id;
-- sort Select * from j5p_1 inner join j5p_2 on j5p_1.id=j5p_2.id inner join j5p_3 on j5p_1.id=j5p_3.id;
-- sort Select * from j5p_1 inner join j5p_2 on j5p_1.id=j5p_2.id and j5p_2.num>13 where j5p_1.name='b';
-- sort Select * from j5p_1 inner join j5p_2 on j5p_1.id=j5p_2.id and j5p_2.num>13 where j5p_1.name='a';
-- sort Select * from j5p_1 inner join j5p_2 on j5p_1.id=j5p_2.id and j5p_2.num>23 where j5p_1.name='b';

-- echo 3. empty
select * from j5p_1 inner join j5p_empty_1 on j5p_1.id=j5p_empty_1.id;
select * from j5p_empty_1 inner join j5p_1 on j5p_empty_1.id=j5p_1.id;
select * from j5p_empty_1 inner join j5p_empty_2 on j5p_empty_1.id = j5p_empty_2.id;
select * from j5p_1 inner join j5p_2 on j5p_1.id = j5p_2.id inner join j5p_empty_1 on j5p_1.id=j5p_empty_1.id;
select * from j5p_empty_1 inner join j5p_1 on j5p_empty_1.id=j5p_1.id inner join j5p_2 on j5p_1.id=j5p_2.id;

-- echo fused primary select tables coverage
CREATE TABLE j5p_sel_1(id int, age int, u_name char);
CREATE TABLE j5p_sel_2(id int, age int, u_name char);
CREATE TABLE j5p_sel_3(id int, res int, u_name char);
CREATE TABLE j5p_sel_4(id int, age int, u_name char);
CREATE TABLE j5p_sel_5(id int, res int, u_name char);

INSERT INTO j5p_sel_1 VALUES (1,18,'a');
INSERT INTO j5p_sel_1 VALUES (2,15,'b');
INSERT INTO j5p_sel_2 VALUES (1,20,'a');
INSERT INTO j5p_sel_2 VALUES (2,21,'c');
INSERT INTO j5p_sel_3 VALUES (1,35,'a');
INSERT INTO j5p_sel_3 VALUES (2,37,'a');

INSERT INTO j5p_sel_4 VALUES (1, 2, 'a');
INSERT INTO j5p_sel_4 VALUES (1, 3, 'b');
