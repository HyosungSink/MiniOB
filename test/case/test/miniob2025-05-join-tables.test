INSERT INTO j5p_sel_5 VALUES (2, 12, 'c');

-- sort SELECT * FROM j5p_sel_1,j5p_sel_2,j5p_sel_3;
-- sort SELECT j5p_sel_1.id,j5p_sel_2.u_name,j5p_sel_3.res FROM j5p_sel_1,j5p_sel_2,j5p_sel_3;
Select j5p_sel_1.res FROM j5p_sel_1,j5p_sel_2,j5p_sel_3;

-- sort SELECT * FROM j5p_sel_1,j5p_sel_2,j5p_sel_3 WHERE j5p_sel_1.u_name=j5p_sel_2.u_name AND j5p_sel_2.u_name=j5p_sel_3.u_name;
-- sort SELECT * FROM j5p_sel_1,j5p_sel_2,j5p_sel_3 WHERE j5p_sel_1.id=j5p_sel_2.id AND j5p_sel_3.res=35;
-- sort SELECT * FROM j5p_sel_1,j5p_sel_2,j5p_sel_3 WHERE j5p_sel_1.age<18 AND j5p_sel_2.u_name='c' AND j5p_sel_3.res=35 AND j5p_sel_1.id=j5p_sel_2.id AND j5p_sel_2.id=j5p_sel_3.id;
-- sort SELECT j5p_sel_2.age FROM j5p_sel_1,j5p_sel_2 WHERE j5p_sel_1.age<18 AND j5p_sel_2.u_name='c' AND j5p_sel_1.id=j5p_sel_2.id;

-- sort SELECT * from j5p_sel_4, j5p_sel_5 where j5p_sel_4.id=j5p_sel_5.id;
-- sort select * from j5p_sel_4, j5p_sel_5 where j5p_sel_4.id >= j5p_sel_5.id;

