-- sort select * from j5p_large_1 inner join j5p_large_2 on j5p_large_1.id=j5p_large_2.id inner join j5p_large_3 on j5p_large_1.id=j5p_large_3.id inner join j5p_large_4 on j5p_large_3.id=j5p_large_4.id inner join j5p_large_5 on 1=1 inner join j5p_large_6 on j5p_large_5.id=j5p_large_6.id where j5p_large_3.num3 <10 and j5p_large_5.num5>90;

-- echo fused dblab hash join coverage
-- echo initialization
CREATE TABLE j5h_1(id int, name char);
CREATE TABLE j5h_2(id int, num int);
CREATE TABLE j5h_3(id int, num2 int);
create table j5h_empty_1(id int, num_empty_1 int);

INSERT INTO j5h_1 VALUES (1, 'a');
INSERT INTO j5h_1 VALUES (2, 'b');
INSERT INTO j5h_1 VALUES (3, 'c');
INSERT INTO j5h_2 VALUES (1, 2);
INSERT INTO j5h_2 VALUES (2, 15);
INSERT INTO j5h_3 VALUES (1, 120);
INSERT INTO j5h_3 VALUES (3, 800);

-- echo hash join

set hash_join = 1;

-- ensure:hashjoin select * from j5h_1 inner join j5h_2 on j5h_1.id = j5h_2.id;
-- sort select * from j5h_1 inner join j5h_2 on j5h_1.id = j5h_2.id;

-- ensure:hashjoin*2 Select * from j5h_1 inner join j5h_2 on j5h_1.id=j5h_2.id inner join j5h_3 on j5h_1.id=j5h_3.id;
-- sort Select * from j5h_1 inner join j5h_2 on j5h_1.id=j5h_2.id inner join j5h_3 on j5h_1.id=j5h_3.id;

-- ensure:hashjoin Select * from j5h_1 inner join j5h_2 on j5h_1.id=j5h_2.id inner join j5h_3 on j5h_1.id<j5h_3.id;
-- sort Select * from j5h_1 inner join j5h_2 on j5h_1.id=j5h_2.id inner join j5h_3 on j5h_1.id<j5h_3.id;

-- ensure:nlj Select * from j5h_1 inner join j5h_2 on j5h_1.id=j5h_2.id inner join j5h_3 on j5h_1.id<j5h_3.id;
-- sort Select * from j5h_1 inner join j5h_2 on j5h_1.id=j5h_2.id inner join j5h_3 on j5h_1.id<j5h_3.id;

-- ensure:nlj Select * from j5h_1 inner join j5h_2 on j5h_2.num>13 where j5h_1.name='b';
-- sort Select * from j5h_1 inner join j5h_2 on j5h_2.num>13 where j5h_1.name='b';

-- ensure:nlj Select * from j5h_1 inner join j5h_2 on j5h_2.num>13 where j5h_1.name='a';
-- sort Select * from j5h_1 inner join j5h_2 on j5h_2.num>13 where j5h_1.name='a';

-- ensure:nlj Select * from j5h_1 inner join j5h_2 on j5h_2.num>23 where j5h_1.name='b';
-- sort Select * from j5h_1 inner join j5h_2 on j5h_2.num>23 where j5h_1.name='b';

-- ensure:hashjoin select * from j5h_1 inner join j5h_empty_1 on j5h_1.id=j5h_empty_1.id;
select * from j5h_1 inner join j5h_empty_1 on j5h_1.id=j5h_empty_1.id;

-- ensure:hashjoin select * from j5h_empty_1 inner join j5h_1 on j5h_empty_1.id=j5h_1.id;
select * from j5h_empty_1 inner join j5h_1 on j5h_empty_1.id=j5h_1.id;

