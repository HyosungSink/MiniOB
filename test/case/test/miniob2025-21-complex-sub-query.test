-- sort select id from complex_user where dept in (select dept from complex_user where id in (select uid from complex_order where amount>=300));
select id from complex_user where score=(select max(score) from complex_user where dept=20);

-- echo complex sub query boundary errors
select id from complex_user where score=(select amount from complex_order where uid=1);
select id from complex_user where exists (select missing_col from complex_order where complex_order.uid=complex_user.id);
