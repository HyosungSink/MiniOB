-- echo miniob2025 fulltext json score format
CREATE TABLE texts (id INT, content TEXT);
INSERT INTO texts VALUES (0, '如何在OceanBase数据库中使用SQL函数对JSON数据进行操作？');
INSERT INTO texts VALUES (1, '什么是USE_HASH_AGGREGATIONHint的作用及其语法？');
INSERT INTO texts VALUES (2, '列出并简要描述DBMS_DEBUG支持的子程序。');
INSERT INTO texts VALUES (3, 'ignore_replica_checksum_error参数的数据类型是什么？');
ALTER TABLE texts ADD FULLTEXT INDEX idx_texts_jieba (content) WITH PARSER jieba;
SELECT id, content, MATCH(content) AGAINST('JSON数据类型概述') AS score FROM texts WHERE MATCH(content) AGAINST('JSON数据类型概述') > 0 ORDER BY MATCH(content) AGAINST('JSON数据类型概述') DESC, id ASC;
SELECT match_against('JSON', 'JSON') AS score;
