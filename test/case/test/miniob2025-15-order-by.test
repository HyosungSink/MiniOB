-- echo miniob2025 15 order by setup
create table order_t(id int, age int, score float, tag char);
insert into order_t values(1, 20, 2.5, 'b');
insert into order_t values(2, 20, 3.5, 'a');
insert into order_t values(3, 10, null, 'c');
insert into order_t values(4, 30, 1.5, 'd');

-- echo order by checks
select id, age from order_t order by age asc, id desc;
select id, score from order_t order by score desc, id asc;
select id, tag from order_t order by tag asc limit 3;
select id, age + 1 as next_age from order_t order by age + 1 desc, id asc;

-- echo order by boundary errors
select id from order_t order by missing_col;
select id from order_t order by;

-- echo fused primary and dblab order by coverage
-- echo 1. create table
create table p15_order_by(id int, score float, name char);
create table p15_order_by_2(id int, age int);

-- echo 2. insert records
insert into p15_order_by values(3, 1.0, 'a');
insert into p15_order_by values(1, 2.0, 'b');
insert into p15_order_by values(4, 3.0, 'c');
insert into p15_order_by values(3, 2.0, 'c');
insert into p15_order_by values(3, 4.0, 'c');
insert into p15_order_by values(3, 3.0, 'd');
insert into p15_order_by values(3, 2.0, 'f');

insert into p15_order_by_2 values(1, 10);
insert into p15_order_by_2 values(2, 20);
insert into p15_order_by_2 values(3, 10);
insert into p15_order_by_2 values(3, 20);
insert into p15_order_by_2 values(3, 40);
insert into p15_order_by_2 values(4, 20);

-- echo 3. primary order by
-- sort select * from p15_order_by order by id;

-- sort select * from p15_order_by order by id asc;

-- sort select * from p15_order_by order by id desc;

-- sort select * from p15_order_by order by score desc;

-- sort select * from p15_order_by order by name desc;

-- echo 4. order by more than one fields
select * from p15_order_by order by id, score, name;

select * from p15_order_by order by id desc, score asc, name desc;

-- echo 5. order by associate with where condition
select * from p15_order_by where id=3 and name>='a' order by score desc, name;

-- echo 6. multi-table order by
select * from p15_order_by,p15_order_by_2 order by p15_order_by.id,p15_order_by.score,p15_order_by.name,p15_order_by_2.id,p15_order_by_2.age;

select * from p15_order_by, p15_order_by_2 where p15_order_by.id=p15_order_by_2.id order by p15_order_by.score desc, p15_order_by_2.age asc, p15_order_by.id asc, p15_order_by.name;

-- echo fused vectorized order by limit coverage
-- echo 1. create table
set execution_mode='chunk_iterator';

create table t_order_by(id int, score float, name char) storage format=pax;
create table t_order_by_2(id int, age int) storage format=pax;

-- echo 2. insert records
insert into t_order_by values(3, 1.0, 'a');
insert into t_order_by values(1, 2.0, 'b');
insert into t_order_by values(4, 3.0, 'c');
insert into t_order_by values(3, 2.0, 'c');
insert into t_order_by values(3, 4.0, 'c');
insert into t_order_by values(3, 3.0, 'd');
insert into t_order_by values(3, 2.0, 'f');

insert into t_order_by_2 values(1, 10);
insert into t_order_by_2 values(2, 20);
insert into t_order_by_2 values(3, 10);
insert into t_order_by_2 values(3, 20);
insert into t_order_by_2 values(3, 40);
insert into t_order_by_2 values(4, 20);

-- sort select * from t_order_by order by id;

-- sort select * from t_order_by order by id asc limit 1;

-- sort select * from t_order_by order by id desc limit 10;

-- sort select * from t_order_by order by score desc limit 100;

-- echo 4. order by more than one fields
select * from t_order_by order by id, score;

select * from t_order_by order by id desc, score asc limit 1;

-- echo 5. order by associate with where condition
select * from t_order_by where id=3 order by score desc limit 100;
