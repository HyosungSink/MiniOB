-- echo official miniob2025-16-vector-basic-official
DROP TABLE vec_t1;
DROP TABLE vec_bad_arity;
DROP TABLE vec_big_ok;
DROP TABLE vec_big_bad;

# -- 1) 基础：建表 + 插入（VECTOR(3)）

CREATE TABLE vec_t1 (id INT, c1 VECTOR(3));

# -- 期望：SUCCESS

INSERT INTO vec_t1 VALUES (1, STRING_TO_VECTOR('[1, 2, 3]')), (2, STRING_TO_VECTOR('[2, 3, 4]')), (3, STRING_TO_VECTOR('[0, 4, 3]'));

# -- 与 [0,0,0] 的欧氏距离为 5（3-4-5 三元组）
# -- 期望：SUCCESS

# -- 查询时用 VECTOR_TO_STRING 包裹向量列
SELECT id, VECTOR_TO_STRING(c1) AS vec_str FROM vec_t1 ORDER BY id;

# -- 正确输出（字符串格式示例，具体科学计数法显示以实现为准）：
# -- 1 | [1.00000e+00,2.00000e+00,3.00000e+00]
# -- 2 | [2.00000e+00,3.00000e+00,4.00000e+00]
# -- 3 | [0.00000e+00,4.00000e+00,3.00000e+00]


# -- 2) 距离计算（常量 vs 常量；列 vs 常量）


# -- 2.1 常量 vs 常量：三种距离
SELECT DISTANCE(STRING_TO_VECTOR('[1,2,3]'), STRING_TO_VECTOR('[2,3,4]'), 'EUCLIDEAN') AS dist_euc, DISTANCE(STRING_TO_VECTOR('[1,0,0]'), STRING_TO_VECTOR('[0,1,0]'), 'COSINE') AS dist_cos, DISTANCE(STRING_TO_VECTOR('[1,2,3]'), STRING_TO_VECTOR('[2,3,4]'), 'DOT') AS dist_dot;

# -- 正确输出（数值示例）：
# -- dist_euc | dist_cos | dist_dot
# -- 1.73205  | 1        | 20

# -- 2.2 列 vs 常量：欧氏距离（id=3 应为 5）
SELECT id, DISTANCE(c1, STRING_TO_VECTOR('[0,0,0]'), 'EUCLIDEAN') AS dist_from_origin FROM vec_t1 ORDER BY id;

# -- 正确输出（关键信息）：
# -- id=3 的 dist_from_origin = 5


# -- 3) 互转与同义词：STRING_TO_VECTOR / VECTOR_TO_STRING

# -- 3.1 互转闭环（原样返回）
SELECT VECTOR_TO_STRING(STRING_TO_VECTOR('[3.07, -1.24]')) AS roundtrip;

# -- 正确输出（示例，科学计数法、5位小数）：
-- connect 3.07000e+00,-1.24000e+00
-- connection 3.07000e+00,-1.24000e+00

# -- 3.2 同义词（如实现支持）：TO_VECTOR / FROM_VECTOR / VECTOR_DISTANCE
SELECT VECTOR_TO_STRING(TO_VECTOR('[1, 2, 3]')) AS to_vec_ok, FROM_VECTOR(STRING_TO_VECTOR('[4, 5, 6]')) AS from_vec_ok, VECTOR_DISTANCE(STRING_TO_VECTOR('[1,0,0]'), STRING_TO_VECTOR('[0,1,0]'), 'COSINE') AS vd_cos;

# -- 期望：SUCCESS；vd_cos = 1

# -- 4) 维度与语法边界（应 FAILURE 的场景）

# -- 4.1 维度不匹配：列为 VECTOR(3)，插入二维或四维应失败
INSERT INTO vec_t1 VALUES (10, STRING_TO_VECTOR('[1,2]'));

# -- 期望：FAILURE（维度不匹配）

INSERT INTO vec_t1 VALUES (11, STRING_TO_VECTOR('[1,2,3,4]'));

# -- 期望：FAILURE（维度不匹配）

# -- 4.2 解析失败：非法字符串（非数值）
INSERT INTO vec_t1 VALUES (12, STRING_TO_VECTOR('[1, a, 3]'));

# -- 期望：FAILURE（无法解析向量值）

# -- 4.3 语法错误：VECTOR() 空括号定义不允许
CREATE TABLE vec_bad_arity (v VECTOR());

# -- 期望：FAILURE（语法错误）

# -- 4.4 最大维度：16383 合法；超过应失败（仅建表校验）
CREATE TABLE vec_big_ok (v VECTOR(16383));

# -- 期望：SUCCESS

CREATE TABLE vec_big_bad (v VECTOR(16384));

# -- 期望：FAILURE（超过最大条目数 16383）

# -- 5) 比较语义：仅支持向量与向量相等比较；其他比较应失败

# -- 5.1 相等比较（允许）：查出等于 [1,2,3] 的行
SELECT id FROM vec_t1 WHERE c1 = STRING_TO_VECTOR('[1,2,3]') ORDER BY id;

# -- 正确输出：
# -- 1

# -- 5.2 与非向量比较（不允许）
SELECT * FROM vec_t1 WHERE c1 = 1;

# -- 期望：FAILURE（类型不匹配）

# -- 5.3 其他比较符（不允许）：>, < 等
SELECT * FROM vec_t1 WHERE c1 > STRING_TO_VECTOR('[1,1,1]');

# -- 期望：FAILURE（不支持的比较操作）

