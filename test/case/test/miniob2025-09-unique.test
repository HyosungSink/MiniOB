-- echo miniob2025 09 unique setup
create table unique_t(id int, email int, region int, tag char);
create unique index idx_unique_email on unique_t(email);
create unique index idx_unique_region_tag on unique_t(region, tag);
insert into unique_t values(1, 100, 1, 'a');
insert into unique_t values(2, 200, 1, 'b');

-- echo unique checks
insert into unique_t values(3, 300, 2, 'a');
-- sort select id, email, region, tag from unique_t;
insert into unique_t values(4, 100, 3, 'c');
insert into unique_t values(5, 500, 1, 'a');
update unique_t set email=200 where id=3;
drop index idx_unique_email on unique_t;
insert into unique_t values(6, 100, 3, 'd');
-- sort select id, email from unique_t;

-- echo unique boundary errors
drop index missing_unique_idx on unique_t;
create unique index idx_unique_bad on unique_t(missing_col);

