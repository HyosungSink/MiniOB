MINIOB2025 CROSS TOPIC SETUP
CREATE TABLE CROSS_USER(ID INT NOT NULL, AGE INT NULL, SCORE FLOAT, BIRTHDAY DATE, NAME CHAR);
SUCCESS
CREATE TABLE CROSS_ORDER(UID INT, AMOUNT INT, NOTE CHAR);
SUCCESS
CREATE UNIQUE INDEX IDX_CROSS_USER_ID ON CROSS_USER(ID);
SUCCESS
CREATE INDEX IDX_CROSS_USER_AGE_SCORE ON CROSS_USER(AGE, SCORE);
SUCCESS
