JOINS EXPRESSIONS FUNCTIONS GROUP BY ORDER BY
SELECT U.ID, U.NAME, O.AMOUNT, U.SCORE + O.AMOUNT AS TOTAL FROM CROSS_USER AS U INNER JOIN CROSS_ORDER AS O ON U.ID=O.UID WHERE O.AMOUNT>=100 ORDER BY U.ID ASC, O.AMOUNT DESC;
1 | A | 100 | 101.5
1 | A | 200 | 201.5
3 | C | 300 | 303.5
ID | NAME | AMOUNT | TOTAL
