MINIOB2025 02 UPDATE SETUP
CREATE TABLE UPDATE_T(ID INT, AGE INT, SCORE FLOAT, TAG CHAR);
SUCCESS
CREATE INDEX IDX_UPDATE_ID ON UPDATE_T(ID);
SUCCESS
CREATE INDEX IDX_UPDATE_AGE ON UPDATE_T(AGE);
SUCCESS
INSERT INTO UPDATE_T VALUES(1, 10, 1.5, 'A');
SUCCESS
INSERT INTO UPDATE_T VALUES(2, 20, 2.5, 'B');
SUCCESS
INSERT INTO UPDATE_T VALUES(3, 20, 3.5, 'C');
SUCCESS

UPDATE CHECKS
UPDATE UPDATE_T SET SCORE=9.5 WHERE ID=1;
SUCCESS
SELECT ID, SCORE FROM UPDATE_T WHERE ID=1;
ID | SCORE
1 | 9.5
UPDATE UPDATE_T SET AGE=30 WHERE AGE=20;
SUCCESS
SELECT ID, AGE FROM UPDATE_T;
1 | 10
2 | 30
3 | 30
ID | AGE
UPDATE UPDATE_T SET TAG='Z';
SUCCESS
SELECT ID, TAG FROM UPDATE_T;
1 | Z
2 | Z
3 | Z
ID | TAG

UPDATE BOUNDARY ERRORS
UPDATE UPDATE_T SET MISSING_COL=1 WHERE ID=1;
FAILURE
UPDATE MISSING_UPDATE_T SET AGE=1 WHERE ID=1;
FAILURE
UPDATE UPDATE_T SET AGE='BAD' WHERE ID=1;
FAILURE

FUSED PRIMARY UPDATE COVERAGE
INITIALIZATION
CREATE TABLE UPDATE_TABLE_1(ID INT, T_NAME CHAR, COL1 INT, COL2 INT);
SUCCESS
CREATE INDEX INDEX_ID ON UPDATE_TABLE_1(ID);
SUCCESS
INSERT INTO UPDATE_TABLE_1 VALUES (1,'N1',1,1);
SUCCESS
INSERT INTO UPDATE_TABLE_1 VALUES (2,'N2',1,1);
SUCCESS
INSERT INTO UPDATE_TABLE_1 VALUES (3,'N3',2,1);
SUCCESS

1. UPDATE A ROW
UPDATE UPDATE_TABLE_1 SET T_NAME='N01' WHERE ID=1;
SUCCESS
SELECT * FROM UPDATE_TABLE_1;
1 | N01 | 1 | 1
2 | N2 | 1 | 1
3 | N3 | 2 | 1
ID | T_NAME | COL1 | COL2

2. UPDATE ROWS
UPDATE UPDATE_TABLE_1 SET COL2=0 WHERE COL1=1;
SUCCESS
SELECT * FROM UPDATE_TABLE_1;
1 | N01 | 1 | 0
2 | N2 | 1 | 0
3 | N3 | 2 | 1
ID | T_NAME | COL1 | COL2

3. UPDATE A INDEX COLUMN
UPDATE UPDATE_TABLE_1 SET ID=4 WHERE T_NAME='N3';
SUCCESS
SELECT * FROM UPDATE_TABLE_1;
1 | N01 | 1 | 0
2 | N2 | 1 | 0
4 | N3 | 2 | 1
ID | T_NAME | COL1 | COL2

4. UPDATE WITHOUT CONDITIONS
UPDATE UPDATE_TABLE_1 SET COL1=0;
SUCCESS
SELECT * FROM UPDATE_TABLE_1;
1 | N01 | 0 | 0
2 | N2 | 0 | 0
4 | N3 | 0 | 1
ID | T_NAME | COL1 | COL2

5. UPDATE WITH CONDITIONS
UPDATE UPDATE_TABLE_1 SET T_NAME='N02' WHERE COL1=0 AND COL2=0;
SUCCESS
SELECT * FROM UPDATE_TABLE_1;
1 | N02 | 0 | 0
2 | N02 | 0 | 0
4 | N3 | 0 | 1
ID | T_NAME | COL1 | COL2

6. UPDATE NON-EXISTENT TABLE
UPDATE UPDATE_TABLE_2 SET T_NAME='N01' WHERE ID=1;
FAILURE

7. UPDATE NON-EXISTENT COLUMN
UPDATE UPDATE_TABLE_1 SET T_NAME_FALSE='N01' WHERE ID=1;
FAILURE

8. UPDATE WITH INVALID CONDITION
UPDATE UPDATE_TABLE_1 SET T_NAME='N01' WHERE ID_FALSE=1;
FAILURE

9. UPDATE IN VAIN
UPDATE UPDATE_TABLE_1 SET T_NAME='N01' WHERE ID=100;
SUCCESS
SELECT * FROM UPDATE_TABLE_1;
1 | N02 | 0 | 0
2 | N02 | 0 | 0
4 | N3 | 0 | 1
ID | T_NAME | COL1 | COL2

10. UPDATE WITH INVALID VALUE
UPDATE UPDATE_TABLE_1 SET COL1='N01' WHERE ID=1;
FAILURE
