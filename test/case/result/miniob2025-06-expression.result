MINIOB2025 06 EXPRESSION SETUP
CREATE TABLE EXPR_T(ID INT, A INT, B INT, C FLOAT);
SUCCESS
INSERT INTO EXPR_T VALUES(1, 10, 2, 1.5);
SUCCESS
INSERT INTO EXPR_T VALUES(2, 5, 0, 2.5);
SUCCESS
INSERT INTO EXPR_T VALUES(3, -3, 4, 3.5);
SUCCESS

EXPRESSION CHECKS
SELECT ID, A + B AS ADD_VALUE, A - B AS SUB_VALUE FROM EXPR_T WHERE ID=1;
ID | ADD_VALUE | SUB_VALUE
1 | 12 | 8
SELECT ID, A * B AS MUL_VALUE, A / B AS DIV_VALUE FROM EXPR_T;
1 | 20 | 5
2 | 0 | NULL
3 | -12 | -0.75
ID | MUL_VALUE | DIV_VALUE
SELECT ID FROM EXPR_T WHERE 5 + B < A + 6;
1
2
ID
SELECT ID, (A + B) * 2 AS NESTED_VALUE FROM EXPR_T WHERE ID=3;
ID | NESTED_VALUE
3 | 2

EXPRESSION BOUNDARY CHECKS
SELECT ID, A / B AS DIV_ZERO FROM EXPR_T WHERE ID=2;
ID | DIV_ZERO
2 | NULL
SELECT UNKNOWN_COL + 1 FROM EXPR_T;
FAILURE
SELECT ID FROM EXPR_T WHERE A + > 0;
FAILURE
