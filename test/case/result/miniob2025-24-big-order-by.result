MINIOB2025 BIG ORDER BY SETUP
CREATE TABLE BIG_ORDER_A(A1 INT, A2 INT, A3 INT, A4 INT, A5 INT, A6 INT, A7 INT, A8 INT, A9 INT, A10 INT, A11 INT, A12 INT, A13 INT, A14 INT, A15 INT, A16 INT, A17 INT, A18 INT, A19 INT, A20 INT);
