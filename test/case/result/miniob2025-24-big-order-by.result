CREATE TABLE BIG_ORDER_B(B1 INT, B2 INT, B3 INT, B4 INT, B5 INT, B6 INT, B7 INT, B8 INT, B9 INT, B10 INT, B11 INT, B12 INT, B13 INT, B14 INT, B15 INT, B16 INT, B17 INT, B18 INT, B19 INT, B20 INT);
