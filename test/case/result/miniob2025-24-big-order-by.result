CREATE TABLE BIG_ORDER_C(C1 INT, C2 INT, C3 INT, C4 INT, C5 INT, C6 INT, C7 INT, C8 INT, C9 INT, C10 INT, C11 INT, C12 INT, C13 INT, C14 INT, C15 INT, C16 INT, C17 INT, C18 INT, C19 INT, C20 INT);
SUCCESS
CREATE TABLE BIG_ORDER_D(D1 INT, D2 INT, D3 INT, D4 INT, D5 INT, D6 INT, D7 INT, D8 INT, D9 INT, D10 INT, D11 INT, D12 INT, D13 INT, D14 INT, D15 INT, D16 INT, D17 INT, D18 INT, D19 INT, D20 INT);
