DROP TABLE IF EXISTS TEXTS;
FAILURE
CREATE TABLE TEXTS (ID INT, CONTENT TEXT);
SUCCESS

INSERT INTO TEXTS VALUES (0, '在OCEANBASE数据库中，REMOVE_RULE过程的作用是什么？'), (1, 'TO_SECONDS函数的返回值是什么？如果输入为NULL，它会返回什么？'), (2, 'OCEANBASE数据库告警系统如何实现对主机、数据库风险和故障的预警？'), (3, 'SYS租户和用户租户在查看CLIENTSESSION时有什么区别？');
SUCCESS

ALTER TABLE TEXTS ADD FULLTEXT INDEX IDX_TEXTS_JIEBA (CONTENT) WITH PARSER JIEBA;
SUCCESS

SELECT ID, CONTENT, MATCH(CONTENT) AGAINST('REMOVE_RULE') AS SCORE FROM TEXTS WHERE MATCH(CONTENT) AGAINST('REMOVE_RULE') > 0 ORDER BY MATCH(CONTENT) AGAINST('REMOVE_RULE') DESC, ID ASC;
ID | CONTENT | SCORE
