COLUMN ALIASES
SELECT ID AS ALIAS_ID, SCORE AS ALIAS_SCORE FROM ALIAS_T1 WHERE ID=1;
ALIAS_ID | ALIAS_SCORE
1 | 10
SELECT ID ALIAS_ID_NO_AS, NAME ALIAS_NAME_NO_AS FROM ALIAS_T1 WHERE ID=2;
ALIAS_ID_NO_AS | ALIAS_NAME_NO_AS
2 | B
SELECT ID + SCORE AS TOTAL_SCORE FROM ALIAS_T1 WHERE ID=1;
TOTAL_SCORE
11
SELECT COUNT(*) AS ROW_COUNT, AVG(SCORE) AS AVG_SCORE FROM ALIAS_T1;
ROW_COUNT | AVG_SCORE
3 | 16.6667

TABLE ALIASES
SELECT A.ID, A.NAME, B.SCORE FROM ALIAS_T1 AS A, ALIAS_T2 AS B WHERE A.ID=B.ID;
1 | A | 100
2 | B | 200
ID | NAME | SCORE
SELECT A.ID AS LEFT_ID, B.ID AS RIGHT_ID FROM ALIAS_T1 A INNER JOIN ALIAS_T2 B ON A.ID=B.ID;
1 | 1
2 | 2
LEFT_ID | RIGHT_ID
SELECT OUTER_T.ID FROM ALIAS_T1 AS OUTER_T WHERE OUTER_T.ID IN (SELECT INNER_T.ID FROM ALIAS_T2 AS INNER_T);
1
2
ID

