VIEW WITH ALIASES AND FILTERS
CREATE VIEW VIEW_ALIAS AS SELECT ID AS VID, NAME AS VNAME FROM VIEW_T1 WHERE AGE>=20;
SUCCESS
SELECT * FROM VIEW_ALIAS;
2 | B
3 | C
VID | VNAME
SELECT VNAME FROM VIEW_ALIAS WHERE VID=2;
VNAME
B

JOIN AND AGGREGATE VIEWS
CREATE VIEW VIEW_JOIN AS SELECT A.ID AS ID, A.AGE AS AGE, B.SCORE AS SCORE FROM VIEW_T1 AS A, VIEW_T2 AS B WHERE A.ID=B.ID;
SUCCESS
SELECT * FROM VIEW_JOIN;
1 | 10 | 100
2 | 20 | 200
ID | AGE | SCORE
INSERT INTO VIEW_JOIN(ID, AGE) VALUES(5, 50);
FAILURE
UPDATE VIEW_JOIN SET AGE=21 WHERE ID=1;
FAILURE

CREATE VIEW VIEW_AGG AS SELECT AGE, COUNT(*) AS CNT FROM VIEW_T1 GROUP BY AGE;
SUCCESS
SELECT * FROM VIEW_AGG;
10 | 1
20 | 1
30 | 1
AGE | CNT
INSERT INTO VIEW_AGG(AGE, CNT) VALUES(1, 1);
FAILURE

