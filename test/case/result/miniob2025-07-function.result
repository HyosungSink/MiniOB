MINIOB2025 07 FUNCTION SETUP
CREATE TABLE FUNCTION_T(ID INT, NAME CHAR, SCORE FLOAT, D DATE);
SUCCESS
INSERT INTO FUNCTION_T VALUES(1, 'A', 1.234, '2020-01-01');
SUCCESS
INSERT INTO FUNCTION_T VALUES(2, 'B', 2.500, '2024-02-29');
SUCCESS
INSERT INTO FUNCTION_T VALUES(3, NULL, NULL, NULL);
SUCCESS

FUNCTION CHECKS
SELECT ID, LENGTH(NAME), ROUND(SCORE), ROUND(SCORE, 1) FROM FUNCTION_T;
1 | 1 | 1 | 1.2
2 | 1 | 2 | 2.5
3 | NULL | NULL | NULL
ID | LENGTH(NAME) | ROUND(SCORE) | ROUND(SCORE, 1)
SELECT DATE_FORMAT(D, '%D,%M,%Y') AS FORMATTED_DATE FROM FUNCTION_T WHERE ID=1;
FORMATTED_DATE
1ST,JANUARY,2020
SELECT DATE_FORMAT(D, 'ABC %Z DEF %N GHI') AS FORMATTED_DATE FROM FUNCTION_T WHERE ID=2;
FORMATTED_DATE
ABC Z DEF N GHI
SELECT LENGTH(NULL), ROUND(NULL), DATE_FORMAT(NULL, '%Y');
LENGTH(NULL) | ROUND(NULL) | DATE_FORMAT(NULL, '%Y')
NULL | NULL | NULL

FUNCTION BOUNDARY ERRORS
SELECT LENGTH() FROM FUNCTION_T;
FAILURE
SELECT ROUND() FROM FUNCTION_T;
FAILURE
SELECT DATE_FORMAT(D) FROM FUNCTION_T;
FAILURE
