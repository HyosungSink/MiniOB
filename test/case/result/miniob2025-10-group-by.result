MINIOB2025 10 GROUP BY SETUP
CREATE TABLE GROUP_T(DEPT INT, CATEGORY CHAR, SCORE FLOAT);
SUCCESS
INSERT INTO GROUP_T VALUES(1, 'A', 10.0);
SUCCESS
INSERT INTO GROUP_T VALUES(1, 'A', 20.0);
SUCCESS
INSERT INTO GROUP_T VALUES(1, 'B', 30.0);
SUCCESS
INSERT INTO GROUP_T VALUES(2, 'A', 40.0);
SUCCESS
INSERT INTO GROUP_T VALUES(2, NULL, NULL);
SUCCESS

GROUP BY CHECKS
SELECT DEPT, COUNT(*), COUNT(SCORE), SUM(SCORE), AVG(SCORE), MIN(SCORE), MAX(SCORE) FROM GROUP_T GROUP BY DEPT;
1 | 3 | 3 | 60 | 20 | 10 | 30
2 | 2 | 1 | 40 | 40 | 40 | 40
DEPT | COUNT(*) | COUNT(SCORE) | SUM(SCORE) | AVG(SCORE) | MIN(SCORE) | MAX(SCORE)
SELECT DEPT, CATEGORY, COUNT(*), SUM(SCORE) FROM GROUP_T GROUP BY DEPT, CATEGORY;
1 | A | 2 | 30
1 | B | 1 | 30
2 | NULL | 1 | NULL
2 | A | 1 | 40
DEPT | CATEGORY | COUNT(*) | SUM(SCORE)
SELECT COUNT(*), COUNT(SCORE), SUM(SCORE), AVG(SCORE) FROM GROUP_T;
COUNT(*) | COUNT(SCORE) | SUM(SCORE) | AVG(SCORE)
5 | 4 | 100 | 25

GROUP BY BOUNDARY ERRORS
SELECT DEPT, SCORE FROM GROUP_T GROUP BY DEPT;
FAILURE
SELECT MISSING_COL, COUNT(*) FROM GROUP_T GROUP BY MISSING_COL;
FAILURE
