LOCAL BIG ORDER CHECKS
SELECT A1, B1, C1, D1 FROM BIG_ORDER_A, BIG_ORDER_B, BIG_ORDER_C, BIG_ORDER_D ORDER BY A1 ASC, B1 DESC, C1 ASC, D1 DESC LIMIT 10;
A1 | B1 | C1 | D1
1 | 4 | 0 | 7
