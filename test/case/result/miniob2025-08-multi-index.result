MINIOB2025 08 MULTI INDEX SETUP
CREATE TABLE MULTI_INDEX_T(ID INT, A INT, B INT, C CHAR);
SUCCESS
CREATE INDEX IDX_MULTI_AB ON MULTI_INDEX_T(A, B);
SUCCESS
INSERT INTO MULTI_INDEX_T VALUES(1, 10, 1, 'A');
SUCCESS
INSERT INTO MULTI_INDEX_T VALUES(2, 10, 2, 'B');
SUCCESS
INSERT INTO MULTI_INDEX_T VALUES(3, 20, 1, 'C');
SUCCESS
INSERT INTO MULTI_INDEX_T VALUES(4, 20, 2, 'D');
SUCCESS

MULTI INDEX CHECKS
SELECT ID, C FROM MULTI_INDEX_T WHERE A=10 AND B>=1;
1 | A
2 | B
ID | C
UPDATE MULTI_INDEX_T SET B=3 WHERE ID=2;
SUCCESS
SELECT ID, A, B FROM MULTI_INDEX_T WHERE A=10;
1 | 10 | 1
2 | 10 | 3
ID | A | B
DELETE FROM MULTI_INDEX_T WHERE A=20 AND B=1;
SUCCESS
SELECT * FROM MULTI_INDEX_T;
1 | 10 | 1 | A
2 | 10 | 3 | B
4 | 20 | 2 | D
ID | A | B | C

MULTI INDEX BOUNDARY ERRORS
CREATE INDEX IDX_MULTI_AB_DUP ON MULTI_INDEX_T(A, MISSING_COL);
FAILURE
CREATE INDEX IDX_MULTI_AB ON MULTI_INDEX_T(A, B);
FAILURE
SELECT * FROM MULTI_INDEX_T WHERE MISSING_COL=1;
FAILURE
