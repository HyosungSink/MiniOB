MINIOB2025 VECTOR SETUP
CREATE TABLE VECTOR_SEARCH_T(ID INT, LABEL CHAR, EMB VECTOR(3));
SUCCESS
INSERT INTO VECTOR_SEARCH_T VALUES(1, 'A', STRING_TO_VECTOR('[1, 0, 0]'));
SUCCESS
INSERT INTO VECTOR_SEARCH_T VALUES(2, 'B', STRING_TO_VECTOR('[0, 1, 0]'));
SUCCESS
INSERT INTO VECTOR_SEARCH_T VALUES(3, 'C', STRING_TO_VECTOR('[0, 0, 1]'));
SUCCESS
INSERT INTO VECTOR_SEARCH_T VALUES(4, 'D', STRING_TO_VECTOR('[1, 1, 0]'));
SUCCESS
INSERT INTO VECTOR_SEARCH_T VALUES(5, 'E', STRING_TO_VECTOR('[-1, 0, 0]'));
SUCCESS

VECTOR CONVERSION AND DISTANCE
SELECT ID, VECTOR_TO_STRING(EMB) AS EMB_TEXT FROM VECTOR_SEARCH_T WHERE ID=1;
ID | EMB_TEXT
1 | [1.00000E+00,0.00000E+00,0.00000E+00]
SELECT DISTANCE(STRING_TO_VECTOR('[1, 0, 0]'), STRING_TO_VECTOR('[0, 1, 0]'), 'EUCLIDEAN') AS DIST_EUC;
DIST_EUC
1.4142135381698608
SELECT DISTANCE(STRING_TO_VECTOR('[1, 0, 0]'), STRING_TO_VECTOR('[0, 1, 0]'), 'COSINE') AS DIST_COS;
DIST_COS
1
SELECT DISTANCE(STRING_TO_VECTOR('[1, 0, 0]'), STRING_TO_VECTOR('[0, 1, 0]'), 'DOT') AS DIST_DOT;
DIST_DOT
0

EXACT VECTOR SEARCH
SELECT ID FROM VECTOR_SEARCH_T ORDER BY DISTANCE(EMB, STRING_TO_VECTOR('[1, 0, 0]'), 'EUCLIDEAN') ASC LIMIT 1;
ID
1
SELECT ID, LABEL FROM VECTOR_SEARCH_T ORDER BY DISTANCE(EMB, STRING_TO_VECTOR('[0, 0, 1]'), 'EUCLIDEAN') ASC, ID ASC LIMIT 3;
ID | LABEL
3 | C
1 | A
2 | B
SELECT ID FROM VECTOR_SEARCH_T ORDER BY DISTANCE(EMB, STRING_TO_VECTOR('[1, 0, 0]'), 'DOT') DESC, ID ASC LIMIT 2;
ID
1
4
SELECT ID FROM VECTOR_SEARCH_T ORDER BY DISTANCE(EMB, STRING_TO_VECTOR('[1, 0, 0]'), 'COSINE') ASC, ID ASC LIMIT 3;
ID
1
4
2

VECTOR BOUNDARY CHECKS
INSERT INTO VECTOR_SEARCH_T VALUES(6, 'F', STRING_TO_VECTOR('[1, 2]'));
SUCCESS
INSERT INTO VECTOR_SEARCH_T VALUES(7, 'G', STRING_TO_VECTOR('[1, X, 3]'));
FAILURE
SELECT DISTANCE(EMB, STRING_TO_VECTOR('[1, 2]'), 'EUCLIDEAN') FROM VECTOR_SEARCH_T;
FAILURE
SELECT DISTANCE(EMB, STRING_TO_VECTOR('[1, 0, 0]'), 'UNKNOWN') FROM VECTOR_SEARCH_T;
FAILURE
