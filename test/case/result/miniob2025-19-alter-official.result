OFFICIAL MINIOB2025-19-ALTER-OFFICIAL

DROP TABLE ALTER_ADD_1;
FAILURE

CREATE TABLE ALTER_ADD_1 (ID INT);
SUCCESS

INSERT INTO ALTER_ADD_1 VALUES (1),(2);
SUCCESS

ALTER TABLE ALTER_ADD_1 ADD COLUMN COL INT;
SUCCESS

INSERT INTO ALTER_ADD_1 VALUES (3,30);
SUCCESS

SELECT ID, COL FROM ALTER_ADD_1 ORDER BY ID;
ID | COL
1 | NULL
2 | NULL
3 | 30




DROP TABLE ALTER_CHANGE_1;
FAILURE

CREATE TABLE ALTER_CHANGE_1 (COL INT, B INT);
SUCCESS

CREATE INDEX IDX_COL ON ALTER_CHANGE_1(COL);
SUCCESS

INSERT INTO ALTER_CHANGE_1 VALUES (10, 1),(20, 2);
SUCCESS

ALTER TABLE ALTER_CHANGE_1 CHANGE COLUMN COL ID INT;
SUCCESS

SELECT ID, B FROM ALTER_CHANGE_1 ORDER BY ID;
ID | B
10 | 1
20 | 2

DROP INDEX IDX_COL ON ALTER_CHANGE_1;
SUCCESS




DROP TABLE ALTER_DROP_1;
FAILURE

CREATE TABLE ALTER_DROP_1 (A INT, COL INT, C INT);
SUCCESS

CREATE INDEX IDX_COL ON ALTER_DROP_1(COL);
SUCCESS

INSERT INTO ALTER_DROP_1 VALUES (1, 100, 9),(2, 200, 8);
SUCCESS

ALTER TABLE ALTER_DROP_1 DROP COLUMN COL;
SUCCESS

SELECT * FROM ALTER_DROP_1 ORDER BY A;
A | C
1 | 9
2 | 8

DROP INDEX IDX_COL ON ALTER_DROP_1;
FAILURE




DROP TABLE ALTER_TABLE_1;
FAILURE
DROP TABLE ALTER_TABLE_2;
FAILURE

CREATE TABLE ALTER_TABLE_1 (A INT, B INT);
SUCCESS

CREATE INDEX IDX_A ON ALTER_TABLE_1(A);
SUCCESS

INSERT INTO ALTER_TABLE_1 VALUES (1, 11),(2, 22);
SUCCESS

ALTER TABLE ALTER_TABLE_1 RENAME TO ALTER_TABLE_2;
SUCCESS

SELECT * FROM ALTER_TABLE_2 ORDER BY A;
A | B
1 | 11
2 | 22

DROP INDEX IDX_A ON ALTER_TABLE_2;
SUCCESS
