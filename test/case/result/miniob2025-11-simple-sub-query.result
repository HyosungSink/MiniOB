MINIOB2025 11 SIMPLE SUB QUERY SETUP
CREATE TABLE SUBQ_USER(ID INT, AGE INT, NAME CHAR);
SUCCESS
CREATE TABLE SUBQ_ORDER(UID INT, AMOUNT INT);
SUCCESS
INSERT INTO SUBQ_USER VALUES(1, 18, 'A');
SUCCESS
INSERT INTO SUBQ_USER VALUES(2, 20, 'B');
SUCCESS
INSERT INTO SUBQ_USER VALUES(3, 30, 'C');
SUCCESS
INSERT INTO SUBQ_ORDER VALUES(1, 100);
SUCCESS
INSERT INTO SUBQ_ORDER VALUES(1, 200);
SUCCESS
INSERT INTO SUBQ_ORDER VALUES(3, 300);
SUCCESS

SIMPLE SUB QUERY CHECKS
SELECT ID, NAME FROM SUBQ_USER WHERE ID IN (SELECT UID FROM SUBQ_ORDER WHERE AMOUNT>=200);
1 | A
3 | C
ID | NAME
SELECT ID, NAME FROM SUBQ_USER WHERE ID NOT IN (SELECT UID FROM SUBQ_ORDER WHERE AMOUNT>250);
1 | A
2 | B
ID | NAME
SELECT ID FROM SUBQ_USER WHERE AGE=(SELECT MAX(AGE) FROM SUBQ_USER);
ID
3
SELECT ID FROM SUBQ_USER WHERE AGE>(SELECT AVG(AGE) FROM SUBQ_USER);
ID
3

SIMPLE SUB QUERY BOUNDARY ERRORS
SELECT ID FROM SUBQ_USER WHERE AGE=(SELECT AMOUNT FROM SUBQ_ORDER);
FAILURE
SELECT ID FROM SUBQ_USER WHERE ID IN (SELECT MISSING_COL FROM SUBQ_ORDER);
FAILURE
