COMPLEX SUB QUERY CHECKS
SELECT U.ID, U.NAME FROM COMPLEX_USER U WHERE EXISTS (SELECT 1 FROM COMPLEX_ORDER O WHERE O.UID=U.ID AND O.AMOUNT>150);
1 | A
