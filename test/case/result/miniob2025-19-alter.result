MINIOB2025 ALTER SETUP
CREATE TABLE ALTER_BASE(ID INT, SCORE INT, NAME CHAR);
SUCCESS
CREATE TABLE ALTER_EXISTING(ID INT);
SUCCESS
INSERT INTO ALTER_BASE VALUES(1, 10, 'A');
SUCCESS
INSERT INTO ALTER_BASE VALUES(2, 20, 'B');
SUCCESS
CREATE INDEX IDX_ALTER_SCORE ON ALTER_BASE(SCORE);
SUCCESS

ADD COLUMN
ALTER TABLE ALTER_BASE ADD COLUMN AGE INT;
SUCCESS
SELECT * FROM ALTER_BASE;
1 | 10 | A | NULL
2 | 20 | B | NULL
ID | SCORE | NAME | AGE
INSERT INTO ALTER_BASE VALUES(3, 30, 'C', 18);
SUCCESS
SELECT * FROM ALTER_BASE;
1 | 10 | A | NULL
2 | 20 | B | NULL
3 | 30 | C | 18
ID | SCORE | NAME | AGE

CHANGE COLUMN
ALTER TABLE ALTER_BASE CHANGE COLUMN AGE YEARS INT;
SUCCESS
UPDATE ALTER_BASE SET YEARS=21 WHERE ID=1;
SUCCESS
SELECT ID, YEARS FROM ALTER_BASE;
1 | 21
2 | NULL
3 | 18
ID | YEARS
SELECT AGE FROM ALTER_BASE;
FAILURE

DROP COLUMN AND INDEX INTERACTION
ALTER TABLE ALTER_BASE DROP COLUMN NAME;
SUCCESS
SELECT * FROM ALTER_BASE;
1 | 10 | 21
2 | 20 | NULL
3 | 30 | 18
ID | SCORE | YEARS
SELECT NAME FROM ALTER_BASE;
FAILURE
ALTER TABLE ALTER_BASE DROP COLUMN SCORE;
SUCCESS
SELECT * FROM ALTER_BASE;
1 | 21
2 | NULL
3 | 18
ID | YEARS
SELECT * FROM ALTER_BASE WHERE SCORE=20;
FAILURE

SELF RENAME AFTER CHANGE COLUMN
CREATE TABLE ALTER_TABLE_1(ID INT);
SUCCESS
CREATE INDEX I_ID ON ALTER_TABLE_1(ID);
SUCCESS
INSERT INTO ALTER_TABLE_1 VALUES(2);
SUCCESS
INSERT INTO ALTER_TABLE_1 VALUES(9);
SUCCESS
ALTER TABLE ALTER_TABLE_1 ADD COLUMN COL INT;
SUCCESS
ALTER TABLE ALTER_TABLE_1 DROP COLUMN ID;
SUCCESS
DELETE FROM ALTER_TABLE_1;
SUCCESS
CREATE INDEX I_COL ON ALTER_TABLE_1(COL);
SUCCESS
ALTER TABLE ALTER_TABLE_1 CHANGE COLUMN COL ID INT;
SUCCESS
SELECT ID FROM ALTER_TABLE_1;
ID
ALTER TABLE ALTER_TABLE_1 RENAME TO ALTER_TABLE_1;
SUCCESS
SELECT ID FROM ALTER_TABLE_1;
ID

RENAME TABLE
ALTER TABLE ALTER_BASE RENAME TO ALTER_RENAMED;
SUCCESS
SELECT * FROM ALTER_RENAMED;
1 | 21
2 | NULL
3 | 18
ID | YEARS
SELECT * FROM ALTER_BASE;
FAILURE

