MINIOB2025 09 UNIQUE SETUP
CREATE TABLE UNIQUE_T(ID INT, EMAIL INT, REGION INT, TAG CHAR);
SUCCESS
CREATE UNIQUE INDEX IDX_UNIQUE_EMAIL ON UNIQUE_T(EMAIL);
SUCCESS
CREATE UNIQUE INDEX IDX_UNIQUE_REGION_TAG ON UNIQUE_T(REGION, TAG);
SUCCESS
INSERT INTO UNIQUE_T VALUES(1, 100, 1, 'A');
SUCCESS
INSERT INTO UNIQUE_T VALUES(2, 200, 1, 'B');
SUCCESS

